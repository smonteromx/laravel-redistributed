{
    "$schema": "https://ui.shadcn.com/schema/registry.json",
    "name": "laravel-redistributed",
    "homepage": "https://github.com/smonteromx/laravel-redistributed",
    "items": [
        {
            "name": "guidelines",
            "type": "registry:item",
            "title": "Laravel AI Guidelines",
            "description": "Laravel Boost AI guidelines covering project architecture, backend and frontend conventions, testing, and quality pipelines for Laravel + Inertia + React applications.",
            "files": [
                {
                    "path": "registry/guidelines/project-architecture.md",
                    "type": "registry:file",
                    "target": "~/.ai/guidelines/project-architecture.md"
                },
                {
                    "path": "registry/guidelines/backend-conventions.md",
                    "type": "registry:file",
                    "target": "~/.ai/guidelines/backend-conventions.md"
                },
                {
                    "path": "registry/guidelines/frontend-conventions.md",
                    "type": "registry:file",
                    "target": "~/.ai/guidelines/frontend-conventions.md"
                },
                {
                    "path": "registry/guidelines/testing.md",
                    "type": "registry:file",
                    "target": "~/.ai/guidelines/testing.md"
                },
                {
                    "path": "registry/guidelines/quality.md",
                    "type": "registry:file",
                    "target": "~/.ai/guidelines/quality.md"
                }
            ]
        },
        {
            "name": "feedback-inertia",
            "type": "registry:item",
            "title": "Backend Feedback (Inertia)",
            "description": "Backend flash feedback for Inertia apps: the Inertia::notify() macro, FlashResponse and EmphasisVariant enums, and AppException for expected domain failures that flash feedback and redirect back.",
            "files": [
                {
                    "path": "registry/laravel/feedback-inertia/app/Enums/FlashResponse.php",
                    "type": "registry:file",
                    "target": "~/app/Enums/FlashResponse.php"
                },
                {
                    "path": "registry/laravel/feedback-inertia/app/Enums/EmphasisVariant.php",
                    "type": "registry:file",
                    "target": "~/app/Enums/EmphasisVariant.php"
                },
                {
                    "path": "registry/laravel/feedback-inertia/app/Exceptions/AppException.php",
                    "type": "registry:file",
                    "target": "~/app/Exceptions/AppException.php"
                },
                {
                    "path": "registry/laravel/feedback-inertia/app/Macros/InertiaNotifyMacro.php",
                    "type": "registry:file",
                    "target": "~/app/Macros/InertiaNotifyMacro.php"
                }
            ]
        },
        {
            "name": "appearance-react",
            "type": "registry:item",
            "title": "Appearance (React)",
            "description": "Light, dark, and system theme handling: the HandleAppearance middleware shares the appearance cookie server-side, and the useAppearance hook persists the theme to localStorage and cookie and applies it client-side.",
            "files": [
                {
                    "path": "registry/laravel/appearance/app/Http/Middleware/HandleAppearance.php",
                    "type": "registry:file",
                    "target": "~/app/Http/Middleware/HandleAppearance.php"
                },
                {
                    "path": "registry/react/appearance/resources/js/hooks/use-appearance.ts",
                    "type": "registry:file",
                    "target": "~/resources/js/hooks/use-appearance.ts"
                },
                {
                    "path": "registry/react/appearance/resources/js/types/ui/appearance.ts",
                    "type": "registry:file",
                    "target": "~/resources/js/types/ui/appearance.ts"
                }
            ]
        }
    ]
}

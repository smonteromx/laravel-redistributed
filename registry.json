        {
            "name": "decorator-react",
            "type": "registry:item",
            "title": "Decorator (React)",
            "description": "Enum decoration pattern: the shared Decoration type and the useDecorator() hook to resolve UI metadata (labels, descriptions, emphasis, icons) from enum-keyed decoration records.",
